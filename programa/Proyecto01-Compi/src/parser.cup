import java_cup.runtime.*;
import java.util.HashMap;
import java.util.ArrayList;
import java.util.List;
/*
 * =========================================================
 *  ANALIZADOR SINTÁCTICO (CUP)
 * =========================================================
 * Este archivo define la gramática del lenguaje y las acciones
 * que se ejecutan durante el análisis sintáctico.
 *
 * El parser recibe los tokens generados por el Lexer y verifica
 * si el programa fuente cumple con las reglas gramaticales.
 * Además, se integra con la tabla de símbolos y con el manejador
 * de errores para registrar información útil durante el análisis.
 */

parser code {:
    /*
     * Referencia al analizador léxico.
     * A través de este objeto el parser obtiene los tokens.
     */
    Lexer lex;

    /*
     * Tabla donde se almacenan funciones, parámetros, variables
     * y arreglos encontrados durante el análisis.
     */
    TablaSimbolos tabla;

    /*
     * Manejador encargado de registrar los errores sintácticos.
     * Se obtiene desde el lexer para centralizar los errores léxicos
     * y sintácticos en un mismo archivo.
     */
    ManejadorErrores manejadorErrores;

    /*
        * Objeto para generar código intermedio (3D).
        * Se utiliza para crear etiquetas, temporales y líneas de código
        * a medida que se procesa el programa fuente.
        */
    Cod3D cod3d;
    
    /*
     * Contadores utilizados para generar nombres únicos de scopes,
     * por ejemplo if1_main, switch1_main, dowhile1_main, etc.
     */
    HashMap<String, Integer> contadores = new HashMap<>();

    /*
     * Última línea y columna leída. Se usan como respaldo cuando
     * ocurre un error y el token no trae una posición clara.
     */
    private int lastLine = 1;
    private int lastColumn = 1;

    /*
     * Tipo del arreglo actual siendo inicializado.
     * Se usa para validar que los valores iniciales tengan el tipo correcto.
     */
    private String tipoArregloActual = null;
    private boolean asignacionEnExpresion = false; // Indica si se está procesando una asignación dentro de una expresión
    private boolean funcionDuplicada = false; // Indica si la función actual es duplicada (scope temporal)
    private String tipoFuncionDuplicada = null; // Guarda el tipo de la función duplicada para validar returns

    /*
     * Contadores para validación de dimensiones de arrays bidimensionales.
     * Se usan para validar que las dimensiones declaradas coincidan con
     * las dimensiones reales en la inicialización.
     */
    private int filasEsperadas = 0;
    private int columnasEsperadas = 0;
    private int filasContadas = 0;
    private int columnasActual = 0;  // Columnas de la fila actual

    /*
     * ArrayList para rastrear valores de case en el switch actual.
     * Se usa para detectar valores de case repetidos dentro del mismo switch.
     */
    private ArrayList<String> casosActuales = new ArrayList<>();

    /*
     * Tipo de la expresión del switch actual.
     * Se usa para validar que cada case sea compatible con el tipo del switch.
     */
    private String tipoSwitchActual = null;
    private String tipoFuncionActual = null; 

    /*
        *Para estructuras de control
        *Atributos a llamar de la clase
        */
    private String etiquetaIfPendiente = "";
    private String etiquetaSwitchActual = "";
    private String valorSwitchActual = "";
    private String banderaSwitchActual = "";
    private String etiquetaFuncionActual = "";

    /*
     * Constructor del parser.
     * Recibe el lexer, crea la tabla de símbolos y obtiene el
     * manejador de errores para poder reportar errores sintácticos.
     */
    public parser(Lexer lex) {
        this.lex = lex;
        this.tabla = new TablaSimbolos();
        this.manejadorErrores = lex.getManejadorErrores();
        this.cod3d = new Cod3D();
    }

    /*
     * Permite acceder a la tabla de símbolos desde el Main.
     * Esto es útil para escribir la tabla al finalizar el análisis.
     */
    public TablaSimbolos getTabla() {
        return tabla;
    }

    /*
     * Genera un nombre único para cada scope interno.
     * Se utiliza principalmente en if, else, do-while y switch.
     */
    private String nuevoScope(String tipo) {
        String key = tipo + "_" + tabla.getCurrentScope();
        int count = contadores.getOrDefault(key, 0) + 1;
        contadores.put(key, count);
        return tipo + count + "_" + tabla.getCurrentScope();
    }

    public String obtenerNombreFuncion(String scope) {
        // Buscamos la posición del último '_'
        int indice = scope.lastIndexOf('_');
        
        // Si encontramos un '_' cortamos el string desde esa posición + 1 hasta el final
        if (indice != -1) {
            return scope.substring(indice + 1);
        }
        
        // Si no tiene '_' (por ejemplo si el scope es solo "main"), devolvemos el mismo string
        return scope;
    }


    /*
     * Método llamado automáticamente por CUP cuando detecta
     * un error sintáctico. Aquí se construye un mensaje claro
     * y se envía al manejador de errores.
     */
    public void syntax_error(Symbol token) {
        String msj;

        if (token == null || token.sym == sym.EOF) {
            msj = "Fin de archivo inesperado";
        } else if (token.value != null) {
            msj = "Token inesperado: " + token.value;
        } else {
            msj = "Token inesperado: " + sym.terminalNames[token.sym];
        }

        if (manejadorErrores != null) {
            manejadorErrores.agregarErrorSintactico(
                msj,
                (token != null ? token.left : lastLine - 1),
                (token != null ? token.right : lastColumn - 1)
            );
        } else {
            System.err.println("Error Sintáctico: " + msj);
        }
    }

    /*
     * Método llamado cuando CUP no logra recuperarse del error.
     * Se deja como último recurso 
     */
    public void unrecovered_syntax_error(Symbol token) throws Exception {
        if (token == null || token.sym == sym.EOF) {
            return;
        }

        String msj = "Error sintáctico no recuperable: token inesperado";

        if (manejadorErrores != null) {
            manejadorErrores.agregarErrorSintactico(
                msj,
                token.left,
                token.right
            );
        }
    }

    private String crearExpr(String valor, String tipo) {
        return valor + ":" + tipo;
    }

    private String getValorExpr(String expr) {
        if (expr == null || !expr.contains(":")) {
            return "";
        }

        return expr.substring(0, expr.lastIndexOf(":"));
    }

    private String getTipoExpr(String expr) {
        if (expr == null || !expr.contains(":")) {
            return "error";
        }

        return expr.substring(expr.lastIndexOf(":") + 1);
    }

:};

init with {: :};
/*
 * Este bloque indica cómo el parser obtiene el siguiente token.
 * Además, actualiza la última línea y columna leída para poder
 * reportar errores con una posición aproximada.
 */
scan with {:
    Symbol token = lex.next_token();

    if (token != null) {
        if (token.left >= 0) lastLine = token.left + 1;
        if (token.right >= 0) lastColumn = token.right + 1;
    }

    return token;
:};

/*
 * =========================================================
 *  TERMINALES
 * =========================================================
 * Los terminales representan los tokens que vienen desde el lexer.
 * Estos nombres deben coincidir con los símbolos retornados en
 * scanner.flex mediante sym.NOMBRE_TOKEN.
 */
terminal IF, ELSE, DO, WHILE, SWITCH, CASE, DEFAULT, BREAK, RETURN;
terminal CIN, COUT, EMPTY, MAIN;
terminal STRING, CHAR, FLOAT, BOOL, INT;
terminal TRUE, FALSE;

terminal EQUAL, N_EQUAL, LESS_T, LESS_TE, GREATHER_T, GREATHER_TE;

terminal ID, ENTERO, FLOTANTE, EXPONENCIAL, FRACCION;
terminal CHAR_LIT, STRING_LITERAL;

terminal ASIGNAR;
terminal INICIO_INDICES, FINAL_INDICES;
terminal INICIO_PAREN, FINAL_PAREN;
terminal INICIO_BLOQUE, FINAL_BLOQUE;
terminal MASMAS, MENOSMENOS;
terminal SUMA, RESTA, MULTI, DIV, MOD, POT;
terminal OR, AND, NOT;
terminal SEPARADOR, FIN_EXPR, COMA, DOS_PUNTOS;

/*
 * =========================================================
 *  NO TERMINALES
 * =========================================================
 * Los no terminales representan las estructuras de la gramática:
 * programa, funciones, bloques, sentencias, expresiones, condiciones,
 * estructuras de control, llamadas a funciones, etc.
 */
non terminal programa, main, funciones, encabezado_funcion, funcion;
non terminal lista_parametros, parametro;
non terminal bloque, lista_sentencias, sentencia;
non terminal llamada_funcion, lista_expresiones;

non terminal tipo;
non terminal creacion, creacion_array;
non terminal asignacion, asignacion_array, acceso_array;
non terminal creacion_asignacion, creacion_asignacion_array;
non terminal valores_array, lista_filas, fila, lista_valores, elemento_valor;

non terminal expresion, expresion_logica, expresion_conjuncion;
non terminal expresion_negacion, expresion_relacional;
non terminal expresion_aritmetica, expresion_termino;
non terminal expresion_factor, expresion_potencia;
non terminal expresion_unarios, expresion_valores;

non terminal primer_termino_or, siguientes_terminos_or;
non terminal primer_termino_and, siguientes_terminos_and;
non terminal primer_termino_arit, siguientes_terminos_arit;
non terminal primer_factor_term, siguientes_factores_term;
non terminal primer_potencia, siguientes_potencias;

non terminal comparacion, equal, n_equal, less_t, less_te, greather_t, greather_te;
non terminal condicion;
non terminal abrir_scope_if, abrir_scope_else;
non terminal if_inicio, else_inicio, if_else_opc;
non terminal abrir_scope_while, do_inicio, condicion_do, abrir_scope_switch;
non terminal bloque_if_else, bloque_do_while, bloque_switch;
non terminal bloque_casos, lista_casos, caso, case_inicio, default_case, default_inicio, sentencias_break;

non terminal break_nt, return_nt, cin_nt, cout_nt;
non terminal literal, numero, bool_lit;

/*
 * Símbolo inicial de la gramática.
 * El análisis sintáctico inicia tratando de reconocer un programa completo.
 */
start with programa;

programa ::= funciones main
             {: tabla.escribirArchivo(); 
                cod3d.escribirArchivo();
            :}
           | main
             {: tabla.escribirArchivo();
                cod3d.escribirArchivo(); 
             :}
           ;

main ::= EMPTY SEPARADOR MAIN INICIO_PAREN FINAL_PAREN
         {: 
            tabla.crearNuevoScope("main");
            cod3d.crearEtiqueta("main"); 
         :}
         bloque
         {: 
            cod3d.crearEtiqueta("main_end"); 
            tabla.salirDelScope();
         :};

funciones ::= funcion funciones
            | funcion;

encabezado_funcion ::= tipo:t SEPARADOR ID:i
                       {:
                            // Validar que no exista otra función con el mismo nombre
                            if (tabla.buscarSimboloEnScope(i.toString(), tabla.getGlobalScope()) != null) {
                                funcionDuplicada = true;
                                tipoFuncionDuplicada = t.toString();
                                manejadorErrores.agregarErrorSemantico(
                                    "Función '" + i + "' ya ha sido declarada",
                                    ileft + 1,
                                    iright + 1
                                );
                                // Crear scope temporal para procesar errores dentro de la función
                                tabla.crearNuevoScope("duplicada_" + i.toString());
                                tipoFuncionActual = t.toString();
                                etiquetaFuncionActual = ""; // No se genera etiqueta para funciones duplicadas
                            } else {
                                funcionDuplicada = false;
                                tipoFuncionDuplicada = null;
                                TablaSimbolos.NodoToken nodo = new TablaSimbolos.NodoToken(
                                    t.toString(),
                                    i.toString(),
                                    ileft + 1,
                                    iright + 1
                                );
                                nodo.setCategoria("funcion");
                                tabla.agregarNodo(nodo);
                                tipoFuncionActual = t.toString();
                                tabla.crearNuevoScope(i.toString());

                                // Generar etiqueta para la función
                                etiquetaFuncionActual = "_" + i.toString();
                                cod3d.crearEtiqueta(etiquetaFuncionActual);
                                cod3d.reiniciarParametros(); 
                            }
                       :}
                    ;

funcion ::= encabezado_funcion INICIO_PAREN lista_parametros FINAL_PAREN bloque:b
            {:
                if (!funcionDuplicada && !getTipoExpr(b.toString()).equals("true")) {
                    manejadorErrores.agregarErrorSemantico(
                        "A la funcion le falta un return",
                        lastLine,
                        lastColumn
                    );
                }

                if (etiquetaFuncionActual != "") {
                    cod3d.crearEtiqueta(etiquetaFuncionActual + "_end");
                    etiquetaFuncionActual = "";
                }
                tabla.salirDelScope();
            :}

          | encabezado_funcion INICIO_PAREN FINAL_PAREN bloque:b
            {:
                if (!funcionDuplicada && !getTipoExpr(b.toString()).equals("true")) {
                    manejadorErrores.agregarErrorSemantico(
                        "A la funcion le falta un return",
                        lastLine,
                        lastColumn
                    );
                }
                if (etiquetaFuncionActual != "") {
                    cod3d.crearEtiqueta(etiquetaFuncionActual + "_end");
                    etiquetaFuncionActual = "";
                }
                tabla.salirDelScope();
            :}

          | encabezado_funcion INICIO_PAREN lista_parametros FINAL_PAREN error FINAL_BLOQUE
            {: tabla.salirDelScope(); :}

          | encabezado_funcion INICIO_PAREN FINAL_PAREN error FINAL_BLOQUE
            {: tabla.salirDelScope(); :}
          ;

lista_parametros ::= parametro COMA lista_parametros
                   | parametro;

parametro ::= tipo:t SEPARADOR ID:i
              {:
                  // Validar que no esté redeclarado en el scope actual de la función
                  if (tabla.existeEnScopeActual(i.toString())) {
                      manejadorErrores.agregarErrorSemantico(
                          "Parámetro '" + i + "' ya ha sido declarado en esta función",
                          ileft + 1,
                          iright + 1
                      );
                  } else if (!funcionDuplicada) {
                      // Solo agregar a la tabla si la función no es duplicada
                      TablaSimbolos.NodoToken nodo = new TablaSimbolos.NodoToken(
                          t.toString(), i.toString(), ileft + 1, iright + 1
                      );
                      nodo.setCategoria("parametro");
                      // Los parámetros se consideran siempre inicializados
                      nodo.setIntentoAsignacion(true);
                      tabla.agregarNodo(nodo);
                      cod3d.genParametro(t.toString(), i.toString());

                      // Agregar el parámetro a la función padre
                      TablaSimbolos.NodoToken nodoFuncion = tabla.buscarSimboloEnScope(
                          tabla.getCurrentScope(),
                          tabla.getParentScope()
                      );
                      if (nodoFuncion != null) {
                          nodoFuncion.agregarParametro(
                              new TablaSimbolos.Parametro(t.toString(), i.toString())
                          );
                      }
                  } else {
                      // Si es duplicada, crear un nodo temporal solo para validar dentro del scope
                      TablaSimbolos.NodoToken nodo = new TablaSimbolos.NodoToken(
                          t.toString(), i.toString(), ileft + 1, iright + 1
                      );
                      nodo.setCategoria("parametro");
                      nodo.setIntentoAsignacion(true);
                      tabla.agregarNodo(nodo);
                  }
              :}
            ;

bloque ::= INICIO_BLOQUE lista_sentencias:l FINAL_BLOQUE
            {: RESULT = l; :}
         | INICIO_BLOQUE FINAL_BLOQUE
            {: RESULT = crearExpr("return", "false"); :}
         | INICIO_BLOQUE error FINAL_BLOQUE
         ;

lista_sentencias ::= sentencia:s lista_sentencias:l
                    {:
                        String returnS = getTipoExpr(s.toString());
                        String returnL = getTipoExpr(l.toString());

                        if (returnS.equals("true") || returnL.equals("true")) {
                            RESULT = crearExpr("return", "true");
                        } else {
                            RESULT = crearExpr("return", "false");
                        }
                    :}
                   | sentencia:s
                   {: RESULT = s; :}
                   | error FIN_EXPR lista_sentencias:l
                   {: RESULT = l; :}
                   | error FIN_EXPR
                   ;

sentencia ::= creacion FIN_EXPR
            {: RESULT = crearExpr("return", "false"); :}
            | asignacion FIN_EXPR
            {: RESULT = crearExpr("return", "false"); :}
            | creacion_array FIN_EXPR
            {: RESULT = crearExpr("return", "false"); :}
            | asignacion_array FIN_EXPR
            {: RESULT = crearExpr("return", "false"); :}
            | creacion_asignacion FIN_EXPR
            {: RESULT = crearExpr("return", "false"); :}
            | creacion_asignacion_array FIN_EXPR
            {: RESULT = crearExpr("return", "false"); :}
            | return_nt:r FIN_EXPR
            {: RESULT = r; :}
            | bloque_if_else:b
            {: RESULT = b; :}
            | bloque_do_while:b
            {: RESULT = b; :}
            | bloque_switch:b
            {: RESULT = b; :}
            | expresion FIN_EXPR
            {: RESULT = crearExpr("return", "false"); :}
            | cin_nt FIN_EXPR
            {: RESULT = crearExpr("return", "false"); :}
            | cout_nt FIN_EXPR
            {: RESULT = crearExpr("return", "false"); :}
            ;

creacion ::= tipo:t SEPARADOR ID:i
             {:
                 // Validar que no esté redeclarada en el scope actual
                 if (tabla.existeEnScopeActual(i.toString())) {
                     manejadorErrores.agregarErrorSemantico(
                         "Variable '" + i + "' ya ha sido declarada en este scope",
                         ileft + 1,
                         iright + 1
                     );
                 } else {
                     TablaSimbolos.NodoToken nodo = new TablaSimbolos.NodoToken(t.toString(), i.toString(), lastLine, lastColumn);
                     nodo.setCategoria("variable");
                     tabla.agregarNodo(nodo);

                     cod3d.crearCodigo("data_" + t.toString() + " " + i.toString());
                 }
             :};

creacion_array ::= tipo:t SEPARADOR ID:i INICIO_INDICES ENTERO FINAL_INDICES INICIO_INDICES ENTERO FINAL_INDICES
                   {:  
                       // Validar que el tipo del arreglo sea int o float
                       if (!t.toString().equals("int") && !t.toString().equals("float")) {
                           manejadorErrores.agregarErrorSemantico(
                               "Los arreglos solo pueden ser de tipo int o float, pero se encontró: " + t,
                               tleft + 1,
                               tright + 1
                           );
                       } else if (tabla.existeEnScopeActual(i.toString())) {
                           // Validar que no esté redeclarada en el scope actual
                           manejadorErrores.agregarErrorSemantico(
                               "Variable '" + i + "' ya ha sido declarada en este scope",
                               ileft + 1,
                               iright + 1
                           );
                       } else {
                           TablaSimbolos.NodoToken nodo = new TablaSimbolos.NodoToken(t.toString(), i.toString(), lastLine, lastColumn);
                           nodo.setCategoria("arreglo");
                           tabla.agregarNodo(nodo);
                       }
                   :};

lista_expresiones ::= expresion:e COMA lista_expresiones:l
                    {: 
                        
                        ArrayList<String> listaExpr = (ArrayList<String>)l;
                        listaExpr.add(0, e.toString());
                        RESULT = listaExpr;
                     :}
                    | expresion:e
                    {:
                        ArrayList<String> listaExpr = new ArrayList<>();
                        listaExpr.add(0, e.toString());
                        RESULT = listaExpr;
                    :};

asignacion ::= ID:i ASIGNAR expresion:e
               {:
                    TablaSimbolos.NodoToken nodo = tabla.buscarSimboloEnScopeAccesible(i.toString());

                    if (nodo == null) {
                        manejadorErrores.agregarErrorSemantico(
                            "La variable '" + i + "' no ha sido declarada",
                            ileft + 1,
                            iright + 1
                        );
                    } else {
                        String tipoVariable = nodo.getTipo();
                        String tipoExpr = getTipoExpr(e.toString());
                        if (!tipoExpr.equals("error") && !tipoVariable.equals(tipoExpr)) {
                            manejadorErrores.agregarErrorSemantico(
                                "No se puede asignar un valor de tipo " + tipoExpr +
                                " a la variable '" + i + "' de tipo " + tipoVariable,
                                ileft + 1,
                                iright + 1
                            );
                        }
                        // Marcar intento de asignación incluso si falló por tipo
                        nodo.setIntentoAsignacion(true);
                        
                        String dir = getValorExpr(e.toString());
                        String temp = cod3d.genTemporal(dir);
                        cod3d.genAsignacion(i.toString(), temp); 
                    }
               :};

asignacion_array ::= ID:i INICIO_INDICES expresion:e1 FINAL_INDICES INICIO_INDICES expresion:e2 FINAL_INDICES ASIGNAR expresion:valor
                     {:  
                         // Validar que el arreglo esté declarado en un scope accesible
                         TablaSimbolos.NodoToken nodo = tabla.buscarSimboloEnScopeAccesible(i.toString());
                         if (nodo == null) {
                             manejadorErrores.agregarErrorSemantico(
                                 "El arreglo '" + i + "' no ha sido declarado",
                                 ileft + 1,
                                 iright + 1
                             );
                         } else if (!nodo.getCategoria().equals("arreglo")) {
                             manejadorErrores.agregarErrorSemantico(
                                 "'" + i + "' no es un arreglo",
                                 ileft + 1,
                                 iright + 1
                             );
                         } else {
                             // Marcar intento de asignación al arreglo
                             nodo.setIntentoAsignacion(true);
                             
                             // Validar que los índices sean int
                             String tipoE1 = getTipoExpr(e1.toString());
                             String tipoE2 = getTipoExpr(e2.toString());
                             
                             if (!tipoE1.equals("int") && !tipoE1.equals("error")) {
                                 manejadorErrores.agregarErrorSemantico(
                                     "El índice del arreglo debe ser int, pero se encontró: " + tipoE1,
                                     e1left + 1,
                                     e1right + 1
                                 );
                             }
                             if (!tipoE2.equals("int") && !tipoE2.equals("error")) {
                                 manejadorErrores.agregarErrorSemantico(
                                     "El índice del arreglo debe ser int, pero se encontró: " + tipoE2,
                                     e2left + 1,
                                     e2right + 1
                                 );
                             }
                             
                             // Validar que el tipo del valor sea igual al tipo del arreglo
                             String tipoArreglo = nodo.getTipo();
                             String tipoValor = getTipoExpr(valor.toString());
                             
                             if (!tipoValor.equals("error") && !tipoArreglo.equals(tipoValor)) {
                                 manejadorErrores.agregarErrorSemantico(
                                     "No se puede asignar un valor de tipo " + tipoValor +
                                     " a un arreglo de tipo " + tipoArreglo,
                                     valorleft + 1,
                                     valorright + 1
                                 );
                             }
                         }
                     :};

acceso_array ::= ID:i INICIO_INDICES expresion:e1 FINAL_INDICES INICIO_INDICES expresion:e2 FINAL_INDICES
                 {:  
                     TablaSimbolos.NodoToken nodo = tabla.buscarSimboloEnScopeAccesible(i.toString());
                     if (nodo == null) {
                         manejadorErrores.agregarErrorSemantico(
                             "El arreglo '" + i + "' no ha sido declarado",
                             ileft + 1,
                             iright + 1
                         );
                         RESULT = crearExpr(i.toString(), "error");
                     } else if (!nodo.getCategoria().equals("arreglo")) {
                         manejadorErrores.agregarErrorSemantico(
                             "'" + i + "' no es un arreglo",
                             ileft + 1,
                             iright + 1
                         );
                         RESULT = crearExpr(i.toString(), "error");
                     } else {
                         // Validar que el arreglo ha sido inicializado
                         if (!nodo.getIntentoAsignacion()) {
                             manejadorErrores.agregarErrorSemantico(
                                 "El arreglo '" + i + "' no ha sido inicializado",
                                 ileft + 1,
                                 iright + 1
                             );
                         }
                         
                         // Validar que los índices sean int
                         String tipoE1 = getTipoExpr(e1.toString());
                         String tipoE2 = getTipoExpr(e2.toString());
                         
                         if (!tipoE1.equals("int") && !tipoE1.equals("error")) {
                             manejadorErrores.agregarErrorSemantico(
                                 "El índice del arreglo debe ser int, pero se encontró: " + tipoE1,
                                 e1left + 1,
                                 e1right + 1
                             );
                         }
                         if (!tipoE2.equals("int") && !tipoE2.equals("error")) {
                             manejadorErrores.agregarErrorSemantico(
                                 "El índice del arreglo debe ser int, pero se encontró: " + tipoE2,
                                 e2left + 1,
                                 e2right + 1
                             );
                         }
                         
                         RESULT = crearExpr(i.toString(), nodo.getTipo());
                     }
                 :};

creacion_asignacion ::= tipo:t SEPARADOR ID:i ASIGNAR expresion:e
                        {:
                            if (tabla.existeEnScopeActual(i.toString())) {
                                manejadorErrores.agregarErrorSemantico(
                                    "Variable '" + i + "' ya ha sido declarada en este scope",
                                    ileft + 1,
                                    iright + 1
                                );
                            } else {
                                String tipoVariable = t.toString();
                                String tipoExpr = getTipoExpr(e.toString());

                                TablaSimbolos.NodoToken nodo = new TablaSimbolos.NodoToken(tipoVariable, i.toString(), lastLine, lastColumn);
                                nodo.setCategoria("variable");
                                
                                if (!tipoExpr.equals("error") && !tipoVariable.equals(tipoExpr)) {
                                    manejadorErrores.agregarErrorSemantico(
                                        "No se puede inicializar la variable '" + i +
                                        "' de tipo " + tipoVariable +
                                        " con un valor de tipo " + tipoExpr,
                                        ileft + 1,
                                        iright + 1
                                    );
                                }
                                // Marcar intento de asignación incluso si falló por tipo
                                nodo.setIntentoAsignacion(true);
                                tabla.agregarNodo(nodo);
                                
                                String dir = getValorExpr(e.toString());
                                cod3d.crearCodigo("data_" + tipoVariable + " " + i.toString());
                                String temp = cod3d.genTemporal(dir);
                                cod3d.genAsignacion(i.toString(), temp);
                            }
                        :};

creacion_asignacion_array ::= tipo:t SEPARADOR ID:i INICIO_INDICES ENTERO:filas FINAL_INDICES INICIO_INDICES ENTERO:columnas FINAL_INDICES ASIGNAR
                               {: 
                                   tipoArregloActual = t.toString();
                                   filasEsperadas = Integer.parseInt(filas.toString());
                                   columnasEsperadas = Integer.parseInt(columnas.toString());
                                   filasContadas = 0;
                                   // columnasDelaPrimeraFila = 0;
                               :}
                               valores_array
                               {:
                                   tipoArregloActual = null;
                                   
                                   // Validar dimensiones del array
                                   if (filasContadas != filasEsperadas) {
                                       manejadorErrores.agregarErrorSemantico(
                                           "Se esperaban " + filasEsperadas + " filas pero se encontraron " + filasContadas,
                                           ileft + 1,
                                           iright + 1
                                       );
                                   }
                                   
                                   // Validar que el tipo del arreglo sea int o float
                                   if (!t.toString().equals("int") && !t.toString().equals("float")) {
                                       manejadorErrores.agregarErrorSemantico(
                                           "Los arreglos solo pueden ser de tipo int o float, pero se encontró: " + t,
                                           tleft + 1,
                                           tright + 1
                                       );
                                   } else if (tabla.existeEnScopeActual(i.toString())) {
                                       // Validar que no esté redeclarada en el scope actual
                                       manejadorErrores.agregarErrorSemantico(
                                           "Variable '" + i + "' ya ha sido declarada en este scope",
                                           ileft + 1,
                                           iright + 1
                                       );
                                   } else {
                                       TablaSimbolos.NodoToken nodo = new TablaSimbolos.NodoToken(t.toString(), i.toString(), lastLine, lastColumn);
                                       nodo.setCategoria("arreglo");
                                       // Marcar intento de asignación para arreglos inicializados
                                       nodo.setIntentoAsignacion(true);
                                       tabla.agregarNodo(nodo);
                                   }
                               :};

valores_array ::= INICIO_BLOQUE lista_filas FINAL_BLOQUE;

lista_filas ::= fila COMA lista_filas
              {: filasContadas++; :}
              | fila
              {: filasContadas++; :};

fila ::= INICIO_BLOQUE lista_valores FINAL_BLOQUE
        {:
            // Validar que el número de columnas coincida con lo esperado
            if (columnasActual != columnasEsperadas) {
                manejadorErrores.agregarErrorSemantico(
                    "Se esperaban " + columnasEsperadas + " columnas pero se encontraron " + columnasActual,
                    lastLine,
                    lastColumn
                );
            }
            
            columnasActual = 0;
        :};

lista_valores ::= elemento_valor COMA lista_valores
                {: columnasActual++; :}
                | elemento_valor
                {: columnasActual++; :};

elemento_valor ::= expresion:e
                 {:
                     if (tipoArregloActual != null) {
                         String tipoReal = getTipoExpr(e.toString());
                         
                         if (!tipoReal.equals("error") && !tipoReal.equals(tipoArregloActual)) {
                             manejadorErrores.agregarErrorSemantico(
                                 "Se esperaba un valor de tipo " + tipoArregloActual + 
                                 " pero se encontró " + tipoReal,
                                 eleft + 1,
                                 eright + 1
                             );
                         }
                     }
                     RESULT = e;
                 :};

llamada_funcion ::= ID:i INICIO_PAREN lista_expresiones:l FINAL_PAREN
                    {:
                        TablaSimbolos.NodoToken nodo = tabla.buscarSimboloEnScope(i.toString(), tabla.getGlobalScope());
                        if (nodo == null) {
                            manejadorErrores.agregarErrorSemantico(
                                "La función '" + i + "' no ha sido declarada",
                                ileft + 1,
                                iright + 1
                            );
                            RESULT = crearExpr(i.toString(), "error");
                        } else if (!nodo.getCategoria().equals("funcion")) {
                            manejadorErrores.agregarErrorSemantico(
                                "'" + i + "' no es una función",
                                ileft + 1,
                                iright + 1
                            );
                            RESULT = crearExpr(i.toString(), "error");
                        } else {
                            ArrayList<String> expresionesRecibidas = (ArrayList<String>) l;
                            List<TablaSimbolos.Parametro> parametrosEsperados = nodo.getParametros();
                            boolean parametrosValidos = true;
                            if (expresionesRecibidas.size() != parametrosEsperados.size()) {
                                manejadorErrores.agregarErrorSemantico(
                                    "La función '" + i + "' espera " +
                                    parametrosEsperados.size() +
                                    " parámetros, pero se recibieron " +
                                    expresionesRecibidas.size(),
                                    ileft + 1,
                                    iright + 1
                                );
                                parametrosValidos = false;
                            } else {
                                for (int ind = 0; ind < expresionesRecibidas.size(); ind++) {
                                    String exprRecibida = expresionesRecibidas.get(ind);
                                    String tipoRecibido = getTipoExpr(exprRecibida);
                                    String tipoEsperado = parametrosEsperados.get(ind).getTipo();
                                    if (!tipoRecibido.equals("error") &&
                                        !tipoRecibido.equals(tipoEsperado)) {
                                        manejadorErrores.agregarErrorSemantico(
                                            "En el parámetro " + (ind + 1) +
                                            " de la función '" + i +
                                            "' se esperaba un valor de tipo " +
                                            tipoEsperado +
                                            " pero se encontró " +
                                            tipoRecibido,
                                            ileft + 1,
                                            iright + 1
                                        );
                                        parametrosValidos = false;
                                    }
                                }
                            }
                            if (parametrosValidos) {
                                for (int ind = 0; ind < expresionesRecibidas.size(); ind++) {
                                    String exprRecibida = expresionesRecibidas.get(ind);
                                    String valorRecibido = getValorExpr(exprRecibida);
                                    String tipoRecibido = getTipoExpr(exprRecibida);
                                    cod3d.genParametroInv(ind + 1,tipoRecibido,valorRecibido);
                                }
                                String tempCall = cod3d.genLlamada(i.toString(),expresionesRecibidas.size());
                                RESULT = crearExpr(tempCall, nodo.getTipo());
                            } else {
                                RESULT = crearExpr(i.toString(), "error");
                            }
                        }
                    :}
                  | ID:i INICIO_PAREN FINAL_PAREN
                  {:
                      TablaSimbolos.NodoToken nodo = tabla.buscarSimboloEnScope(i.toString(), tabla.getGlobalScope());
                      if (nodo == null) {
                          manejadorErrores.agregarErrorSemantico(
                              "La función '" + i + "' no ha sido declarada",
                              ileft + 1,
                              iright + 1
                          );
                          RESULT = crearExpr(i.toString(), "error");
                      } else if (!nodo.getCategoria().equals("funcion")) {
                          manejadorErrores.agregarErrorSemantico(
                              "'" + i + "' no es una función",
                              ileft + 1,
                              iright + 1
                          );
                          RESULT = crearExpr(i.toString(), "error");
                      } else {
                          if (nodo.getParametros().size() > 0) {
                              manejadorErrores.agregarErrorSemantico(
                                  "La función '" + i + "' espera " +
                                  nodo.getParametros().size() +
                                  " parámetros, pero no se proporcionaron",
                                  ileft + 1,
                                  iright + 1
                              );
                              RESULT = crearExpr(i.toString(), "error");
                          } else {
                              String tempCall = cod3d.genLlamada(i.toString(), 0);
                              RESULT = crearExpr(tempCall, nodo.getTipo());
                          }
                      }
                  :};

expresion ::= expresion_logica:e
             {: RESULT = e; :}
           ;

expresion_logica ::= primer_termino_or:p siguientes_terminos_or:s
                    {:
                        String tipoS = getTipoExpr(s.toString());

                        if (tipoS.equals("epsilon")) {
                            RESULT = p;
                        } else {
                            String tipoP = getTipoExpr(p.toString());

                            if (!tipoP.equals("bool") && !tipoP.equals("error")) {
                                manejadorErrores.agregarErrorSemantico(
                                    "El operador OR solo se puede aplicar a bool, pero se encontró " + tipoP,
                                    pleft + 1,
                                    pright + 1
                                );
                                RESULT = crearExpr("or", "error");
                            } else if (tipoS.equals("error")) {
                                RESULT = crearExpr("or", "error");
                            } else {
                                String valorS = getValorExpr(s.toString());
                                String operador = valorS.substring(0, 2);
                                String der = valorS.substring(2);

                                String izq = getValorExpr(p.toString());

                                String tIzq = cod3d.genTemporal(izq);
                                String tDer = cod3d.genTemporal(der);
                                String temp = cod3d.genOperacion(tIzq, operador, tDer);

                                RESULT = crearExpr(temp, "bool");
                            }
                        }
                    :};

primer_termino_or ::= expresion_conjuncion:e
                     {: RESULT = e; :};

siguientes_terminos_or ::= OR expresion_conjuncion:e siguientes_terminos_or:s
                        {:
                            String tipoE = getTipoExpr(e.toString());
                            String tipoS = getTipoExpr(s.toString());

                            if (!tipoE.equals("bool") && !tipoE.equals("error")) {
                                manejadorErrores.agregarErrorSemantico(
                                    "El operador OR solo acepta bool, pero se encontró " + tipoE,
                                    eleft + 1,
                                    eright + 1
                                );
                                RESULT = crearExpr("or", "error");
                            } else if (tipoS.equals("error")) {
                                RESULT = crearExpr("or", "error");
                            } else {
                                RESULT = crearExpr("||" + getValorExpr(e.toString()), "bool");
                            }
                        :}
                         | /* epsilon */
                        {: RESULT = crearExpr("epsilon", "epsilon"); :};

expresion_conjuncion ::= primer_termino_and:p siguientes_terminos_and:s
                        {:
                            String tipoS = getTipoExpr(s.toString());

                            if (tipoS.equals("epsilon")) {
                                RESULT = p;
                            } else {
                                String tipoP = getTipoExpr(p.toString());

                                if (!tipoP.equals("bool") && !tipoP.equals("error")) {
                                    manejadorErrores.agregarErrorSemantico(
                                        "El operador AND solo acepta bool, pero se encontró " + tipoP,
                                        pleft + 1,
                                        pright + 1
                                    );
                                    RESULT = crearExpr("and", "error");
                                } else if (tipoS.equals("error")) {
                                    RESULT = crearExpr("and", "error");
                                } else {
                                    String valorS = getValorExpr(s.toString());
                                    String operador = valorS.substring(0, 2);
                                    String der = valorS.substring(2);

                                    String izq = getValorExpr(p.toString());

                                    String tIzq = cod3d.genTemporal(izq);
                                    String tDer = cod3d.genTemporal(der);
                                    String temp = cod3d.genOperacion(tIzq, operador, tDer);

                                    RESULT = crearExpr(temp, "bool");
                                }
                            }
                        :};

primer_termino_and ::= expresion_negacion:e
                      {: RESULT = e; :};

siguientes_terminos_and ::= AND expresion_negacion:e siguientes_terminos_and:s
                           {:
                                String tipoE = getTipoExpr(e.toString());
                                String tipoS = getTipoExpr(s.toString());

                                if (!tipoE.equals("bool") && !tipoE.equals("error")) {
                                    manejadorErrores.agregarErrorSemantico(
                                        "El operador AND solo acepta bool, pero se encontró " + tipoE,
                                        eleft + 1,
                                        eright + 1
                                    );
                                    RESULT = crearExpr("and", "error");
                                } else if (tipoS.equals("error")) {
                                    RESULT = crearExpr("and", "error");
                                } else {
                                    RESULT = crearExpr("&&" + getValorExpr(e.toString()), "bool");
                                }
                            :}
                            | /* epsilon */
                            {: RESULT = crearExpr("epsilon", "epsilon"); :};

expresion_negacion ::= NOT expresion_negacion:e
                       {:
                           String tipo = getTipoExpr(e.toString());

                           if (!tipo.equals("bool") && !tipo.equals("error")) {
                               manejadorErrores.agregarErrorSemantico(
                                   "El operador NOT solo se puede aplicar a bool, pero se encontró " + tipo,
                                   eleft + 1,
                                   eright + 1
                               );
                               RESULT = crearExpr("not", "error");
                           } else {
                                String valor = getValorExpr(e.toString());
                                String tValor = cod3d.genTemporal(valor);
                                String temp = cod3d.genNegacion(tValor);

                                RESULT = crearExpr(temp, "bool");
                           }
                       :}
                     | expresion_relacional:e
                       {: RESULT = e; :};

expresion_relacional ::= expresion_aritmetica:e
                        {: RESULT = e; :}
                       | comparacion:c
                         {: RESULT = c; :};

comparacion ::= equal:e
                {: RESULT = e; :}
              | n_equal:e
                {: RESULT = e; :}
              | less_t:e
                {: RESULT = e; :}
              | less_te:e
                {: RESULT = e; :}
              | greather_t:e
                {: RESULT = e; :}
              | greather_te:e
                {: RESULT = e; :};

// Los operadores igual y diferente permiten adicionalmente tipo booleano.
// equal y notequal deben funcionar con expresion booleana en general (id,literal,funcion,opRelacional)

equal       ::= EQUAL       INICIO_PAREN expresion_logica:e1 COMA expresion_logica:e2 FINAL_PAREN
                {:
                    String tipo1 = getTipoExpr(e1.toString());
                    String tipo2 = getTipoExpr(e2.toString());

                    if (!tipo1.equals("error") && !tipo2.equals("error")) {
                        if (!tipo1.equals(tipo2)) {
                            manejadorErrores.agregarErrorSemantico(
                                "No se pueden comparar valores de tipo "
                                + tipo1 + " y " + tipo2,
                                e1left + 1,
                                e1right + 1
                            );
                            RESULT = crearExpr("equal", "error");
                        } else {
                            String izq = getValorExpr(e1.toString());
                            String der = getValorExpr(e2.toString());

                            String tIzq = cod3d.genTemporal(izq);
                            String tDer = cod3d.genTemporal(der);

                            String temp = cod3d.genOpRelacionales("equal", tIzq, tDer);

                            RESULT = crearExpr(temp, "bool");
                        }
                    } else {
                        RESULT = crearExpr("equal", "error");
                    }
                :};
n_equal     ::= N_EQUAL     INICIO_PAREN expresion_logica:e1 COMA expresion_logica:e2 FINAL_PAREN
                {:
                    String tipo1 = getTipoExpr(e1.toString());
                    String tipo2 = getTipoExpr(e2.toString());

                    if (!tipo1.equals("error") && !tipo2.equals("error")) {
                        if (!tipo1.equals(tipo2)) {
                            manejadorErrores.agregarErrorSemantico(
                                "No se pueden comparar valores de tipo "
                                + tipo1 + " y " + tipo2,
                                e1left + 1,
                                e1right + 1
                            );
                            RESULT = crearExpr("n_equal", "error");
                        } else {
                            String izq = getValorExpr(e1.toString());
                            String der = getValorExpr(e2.toString());

                            String tIzq = cod3d.genTemporal(izq);
                            String tDer = cod3d.genTemporal(der);

                            String temp = cod3d.genOpRelacionales("n_equal", tIzq, tDer);

                            RESULT = crearExpr(temp, "bool");
                        }
                    } else {
                        RESULT = crearExpr("n_equal", "error");
                    }
                :};
less_t      ::= LESS_T      INICIO_PAREN expresion_aritmetica:e1 COMA expresion_aritmetica:e2 FINAL_PAREN
                {:
                    String tipo1 = getTipoExpr(e1.toString());
                    String tipo2 = getTipoExpr(e2.toString());

                    if (!tipo1.equals("error") && !tipo2.equals("error")) {
                        if (!tipo1.equals(tipo2)) {
                            manejadorErrores.agregarErrorSemantico(
                                "No se pueden comparar valores de tipo "
                                + tipo1 + " y " + tipo2,
                                e1left + 1,
                                e1right + 1
                            );
                            RESULT = crearExpr("less_t", "error");
                        } else if (!tipo1.equals("int") && !tipo1.equals("float")
                        ) {
                            manejadorErrores.agregarErrorSemantico(
                                "El operador less_t solo acepta int y float",
                                e1left + 1,
                                e1right + 1
                            );
                            RESULT = crearExpr("less_t", "error");
                        } else {
                            String izq = getValorExpr(e1.toString());
                            String der = getValorExpr(e2.toString());

                            String tIzq = cod3d.genTemporal(izq);
                            String tDer = cod3d.genTemporal(der);

                            String temp = cod3d.genOpRelacionales("less_t", tIzq, tDer);

                            RESULT = crearExpr(temp, "bool");
                        }
                    } else {
                        RESULT = crearExpr("less_t", "error");
                    }
                :};
less_te     ::= LESS_TE     INICIO_PAREN expresion_aritmetica:e1 COMA expresion_aritmetica:e2 FINAL_PAREN
                {:
                    String tipo1 = getTipoExpr(e1.toString());
                    String tipo2 = getTipoExpr(e2.toString());

                    if (!tipo1.equals("error") && !tipo2.equals("error")) {
                        if (!tipo1.equals(tipo2)) {
