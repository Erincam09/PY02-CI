                            String tIzq = cod3d.genTemporal(izq);
                            String tDer = cod3d.genTemporal(der);

                            String temp = cod3d.genOpRelacionales("greather_te", tIzq, tDer);

                            RESULT = crearExpr(temp, "bool");
                        }
                    } else {
                        RESULT = crearExpr("greather_te", "error");
                    }
                :};

expresion_aritmetica ::= primer_termino_arit:p siguientes_terminos_arit:s
                        {:
                            String tipoS = getTipoExpr(s.toString());

                            if (tipoS.equals("epsilon")) {
                                RESULT = p;
                            } else {
                                String tipoP = getTipoExpr(p.toString());
                                
                                if (!tipoP.equals(tipoS)) {
                                    manejadorErrores.agregarErrorSemantico(
                                        "No se pueden operar valores de tipo "
                                        + tipoP + " y " + tipoS,
                                        pleft + 1,
                                        pright + 1
                                    );
                                    RESULT = crearExpr("arit","error");
                                } else if (!tipoP.equals("int") && !tipoP.equals("float")) {
                                    manejadorErrores.agregarErrorSemantico(
                                        "Las operaciones aritmeticas solo aceptan int y float ",
                                        pleft + 1,
                                        pright + 1
                                    );
                                    RESULT = crearExpr("arit", "error");
                                } else {
                                    String valorS = getValorExpr(s.toString());
                                    String operador = valorS.substring(0, 1);
                                    String der = valorS.substring(1);

                                    String izq = getValorExpr(p.toString());

                                    String tIzq = cod3d.genTemporal(izq);
                                    String tDer = cod3d.genTemporal(der);
                                    String temp = cod3d.genOperacion(tIzq, operador, tDer);

                                    RESULT = crearExpr(temp, tipoP);
                                }
                            }
                        :};

primer_termino_arit ::= expresion_termino:e
                       {: RESULT = e; :};

siguientes_terminos_arit ::= SUMA  expresion_termino:e siguientes_terminos_arit
                            {: 
                                RESULT = crearExpr("+" + getValorExpr(e.toString()), getTipoExpr(e.toString())); 
                            :}
                           | RESTA expresion_termino:e siguientes_terminos_arit
                            {: 
                                RESULT = crearExpr("-" + getValorExpr(e.toString()), getTipoExpr(e.toString())); 
                            :}
                           | /* epsilon */
                           {: RESULT = crearExpr("epsilon", "epsilon"); :};

expresion_termino ::= primer_factor_term:p siguientes_factores_term:s
                       {:
                            String tipoS = getTipoExpr(s.toString());

                            if (tipoS.equals("epsilon")) {
                                RESULT = p;
                            } else {
                                String tipoP = getTipoExpr(p.toString());
                                
                                if (!tipoP.equals(tipoS)) {
                                    manejadorErrores.agregarErrorSemantico(
                                        "No se pueden operar valores de tipo "
                                        + tipoP + " y " + tipoS,
                                        pleft + 1,
                                        pright + 1
                                    );
                                    RESULT = crearExpr("term","error");
                                } else if (!tipoP.equals("int") && !tipoP.equals("float")) {
                                    manejadorErrores.agregarErrorSemantico(
                                        "Las operaciones * / % solo aceptan int y float ",
                                        pleft + 1,
                                        pright + 1
                                    );
                                    RESULT = crearExpr("term", "error");
                                } else {
                                    String valorS = getValorExpr(s.toString());
                                    String operador = valorS.substring(0, 1);
                                    String der = valorS.substring(1);

                                    String izq = getValorExpr(p.toString());

                                    String tIzq = cod3d.genTemporal(izq);
                                    String tDer = cod3d.genTemporal(der);
                                    String temp = cod3d.genOperacion(tIzq, operador, tDer);

                                    RESULT = crearExpr(temp, tipoP);
                                }
                            }
                       :};

primer_factor_term ::= expresion_factor:e
                       {: RESULT = e; :};

siguientes_factores_term ::= MULTI expresion_factor:e siguientes_factores_term
                            {: 
                                RESULT = crearExpr("*" + getValorExpr(e.toString()), getTipoExpr(e.toString())); 
                            :}
                           | DIV   expresion_factor:e siguientes_factores_term
                            {:
                                String valor = getValorExpr(e.toString());
                                String tipo = getTipoExpr(e.toString());

                                if ((tipo.equals("int") || tipo.equals("float")) && (valor.equals("0") || valor.equals("0.0"))) {

                                    manejadorErrores.agregarErrorSemantico(
                                        "No se permite división entre cero",
                                        eleft + 1,
                                        eright + 1
                                    );

                                    RESULT = crearExpr("div", "error");

                                } else {
                                    RESULT = crearExpr("/" + getValorExpr(e.toString()), getTipoExpr(e.toString()));
                                }
                            :}
                           | MOD   expresion_factor:e siguientes_factores_term
                            {: 
                                RESULT = crearExpr("%" + getValorExpr(e.toString()), getTipoExpr(e.toString())); 
                            :}
                           | /* epsilon */
                            {: RESULT = crearExpr("epsilon", "epsilon"); :};

expresion_factor ::= primer_potencia:p siguientes_potencias:s
                       {:
                            String tipoS = getTipoExpr(s.toString());

                            if (tipoS.equals("epsilon")) {
                                RESULT = p;
                            } else {
                                String tipoP = getTipoExpr(p.toString());

                                if (!tipoP.equals(tipoS)) {
                                    manejadorErrores.agregarErrorSemantico(
                                        "No se pueden operar potencias con valores de tipo "
                                        + tipoP + " y " + tipoS,
                                        pleft + 1,
                                        pright + 1
                                    );
                                    RESULT = crearExpr("pot", "error");
                                } else if (!tipoP.equals("int") && !tipoP.equals("float")) {
                                    manejadorErrores.agregarErrorSemantico(
                                        "El operador ^ solo acepta int y float",
                                        pleft + 1,
                                        pright + 1
                                    );
                                    RESULT = crearExpr("pot", "error");
                                } else {
                                    String valorS = getValorExpr(s.toString());
                                    String operador = valorS.substring(0, 1);
                                    String der = valorS.substring(1);

                                    String izq = getValorExpr(p.toString());

                                    String tIzq = cod3d.genTemporal(izq);
                                    String tDer = cod3d.genTemporal(der);
                                    String temp = cod3d.genOperacion(tIzq, operador, tDer);

                                    RESULT = crearExpr(temp, tipoP);
                                }
                            }
                      :};

primer_potencia ::= expresion_potencia:e
                    {: RESULT = e; :};

siguientes_potencias ::= POT expresion_potencia:e siguientes_potencias
                        {: 
                            RESULT = crearExpr("^" + getValorExpr(e.toString()), getTipoExpr(e.toString())); 
                        :}
                       | /* epsilon */
                        {: RESULT = crearExpr("epsilon", "epsilon"); :};

expresion_potencia ::= expresion_unarios:e
                       {: RESULT = e; :};

expresion_unarios ::= MASMAS ID:i
                    {:
                        TablaSimbolos.NodoToken nodo = tabla.buscarSimboloEnScopeAccesible(i.toString());

                        if (nodo == null) {
                            manejadorErrores.agregarErrorSemantico(
                                "La variable '" + i + "' no ha sido declarada",
                                ileft + 1,
                                iright + 1
                            );
                            RESULT = crearExpr(i.toString(), "error");
                        } else {
                            // Validar que la variable ha sido inicializada
                            if (!nodo.getIntentoAsignacion() && !nodo.getCategoria().equals("parametro")) {
                                manejadorErrores.agregarErrorSemantico(
                                    "La variable '" + i + "' no ha sido inicializada",
                                    ileft + 1,
                                    iright + 1
                                );
                            }
                            String tipo = nodo.getTipo();
                            if (tipo.equals("int") || tipo.equals("float")) {
                                if (tipo.equals("int") || tipo.equals("float")) {
                                    String tVar = cod3d.genTemporal(i.toString());
                                    String tUno = cod3d.genTemporal("1");
                                    String temp = cod3d.genOperacion(tVar, "+", tUno);

                                    cod3d.genAsignacion(i.toString(), temp);

                                    RESULT = crearExpr(temp, tipo);
                                }
                            } else {
                                manejadorErrores.agregarErrorSemantico(
                                    "El operador ++ solo se puede aplicar a int y float, se encontró: " + tipo,
                                    ileft + 1,
                                    iright + 1
                                );
                                RESULT = crearExpr(i.toString(), "error");
                            }
                        }
                        
                    :}
                    | MASMAS acceso_array:a
                    {: RESULT = a; :}
                    | MENOSMENOS ID:i
                    {:
                        TablaSimbolos.NodoToken nodo = tabla.buscarSimboloEnScopeAccesible(i.toString());

                        if (nodo == null) {
                            manejadorErrores.agregarErrorSemantico(
                                "La variable '" + i + "' no ha sido declarada",
                                ileft + 1,
                                iright + 1
                            );
                            RESULT = crearExpr(i.toString(), "error");
                        } else {
                            // Validar que la variable ha sido inicializada
                            if (!nodo.getIntentoAsignacion() && !nodo.getCategoria().equals("parametro")) {
                                manejadorErrores.agregarErrorSemantico(
                                    "La variable '" + i + "' no ha sido inicializada",
                                    ileft + 1,
                                    iright + 1
                                );
                            }
                            String tipo = nodo.getTipo();
                            if (tipo.equals("int") || tipo.equals("float")) {
                                String tVar = cod3d.genTemporal(i.toString());
                                String tUno = cod3d.genTemporal("1");
                                String temp = cod3d.genOperacion(tVar, "-", tUno);

                                cod3d.genAsignacion(i.toString(), temp);

                                RESULT = crearExpr(temp, tipo);
                            } else {
                                manejadorErrores.agregarErrorSemantico(
                                    "El operador -- solo se puede aplicar a int y float, se encontró: " + tipo,
                                    ileft + 1,
                                    iright + 1
                                );
                                RESULT = crearExpr(i.toString(), "error");
                            }
                        }
                    :}
                    | MENOSMENOS acceso_array:a
                    {: RESULT = a; :}
                    | RESTA numero:n
                    {:
                        String valor = getValorExpr(n.toString());
                        String tipo = getTipoExpr(n.toString());

                        String temp = cod3d.genTemporal("-" + valor);

                        RESULT = crearExpr(temp, tipo);
                    :}
                    | expresion_valores:e
                    {: RESULT = e; :};

expresion_valores ::= literal:l
                    {: RESULT = l; :}
                    | ID:i
                    {:
                        TablaSimbolos.NodoToken nodo = tabla.buscarSimboloEnScopeAccesible(i.toString());

                        if (nodo == null) {
                            manejadorErrores.agregarErrorSemantico(
                                "La variable '" + i + "' no ha sido declarada",
                                ileft + 1,
                                iright + 1
                            );
                            RESULT = crearExpr(i.toString(), "error");
                        } else {
                            // Validar que la variable ha sido inicializada
                            // (parámetros se consideran siempre inicializados)
                            if (!nodo.getIntentoAsignacion() && !nodo.getCategoria().equals("parametro")) {
                                manejadorErrores.agregarErrorSemantico(
                                    "La variable '" + i + "' no ha sido inicializada",
                                    ileft + 1,
                                    iright + 1
                                );
                            }
                            RESULT = crearExpr(i.toString(),nodo.getTipo());
                        }
                    :}
                    | acceso_array:a
                    {: RESULT = a; :}
                    | llamada_funcion:f
                    {: RESULT = f; :}
                    | INICIO_PAREN expresion:e FINAL_PAREN
                    {: RESULT = e; :};

abrir_scope_if ::=
    {:
        tabla.crearNuevoScope(nuevoScope("if"));
    :}
;

abrir_scope_else ::=
    {:
        tabla.crearNuevoScope(nuevoScope("else"));
    :}
;

condicion ::= expresion_logica:e
              {:
                  String tipo = getTipoExpr(e.toString());

                  if (!tipo.equals("bool") && !tipo.equals("error")) {
                      manejadorErrores.agregarErrorSemantico(
                          "La condición debe ser de tipo bool, pero se encontró " + tipo,
                          eleft + 1,
                          eright + 1
                      );
                  }
                  RESULT = e;
              :};

if_inicio ::= IF SEPARADOR INICIO_PAREN condicion:c FINAL_PAREN abrir_scope_if
              {:
                  String ifTemp = cod3d.nuevoIf();
                  String condi = getValorExpr(c.toString());
                  String etiqueta = obtenerNombreFuncion(tabla.getCurrentScope()) + "_" + ifTemp;
                  cod3d.crearEtiqueta(etiqueta);
                  cod3d.genIf(condi, etiqueta + "_bloque");
                  cod3d.genGoto(etiqueta + "_bloque_end");
                  cod3d.crearEtiqueta(etiqueta + "_bloque");
                  RESULT = etiqueta;
              :}
            ;

bloque_if_else ::= if_inicio:eti bloque:blq1
                   {:
                       tabla.salirDelScope();
                       String etiqueta = eti.toString();
                       cod3d.genGoto(etiqueta + "_end");
                       cod3d.crearEtiqueta(etiqueta + "_bloque_end");
                       etiquetaIfPendiente = etiqueta;
                   :}
                   if_else_opc:ri
                   {:
                       String tipoElse = getTipoExpr(ri.toString());

                       if (tipoElse.equals("epsilon")) {
                           RESULT = crearExpr("return", "false");
                       } else {
                           String returnb1 = getTipoExpr(blq1.toString());
                           String returnb2 = getTipoExpr(ri.toString());

                           if (returnb1.equals("true") && returnb2.equals("true")) {
                               RESULT = crearExpr("return", "true");
                           } else {
                               RESULT = crearExpr("return", "false");
                           }
                       }
                   :}

                 | IF SEPARADOR INICIO_PAREN error FINAL_PAREN
                   abrir_scope_if
                   bloque
                   {:
                       tabla.salirDelScope();
                       RESULT = crearExpr("return", "false");
                   :}
                 ;

else_inicio ::= ELSE SEPARADOR abrir_scope_else
                {:
                    String etiqueta = etiquetaIfPendiente;
                    String etiquetaElse = etiqueta.replace("_if_", "_else_");
                    cod3d.crearEtiqueta(etiquetaElse);
                    RESULT = etiqueta;
                :}
              ;

if_else_opc ::= else_inicio:eti bloque:blq2
                {:
                    tabla.salirDelScope();
                    String etiqueta = eti.toString();
                    String etiquetaElse = etiqueta.replace("_if_", "_else_");
                    cod3d.crearEtiqueta(etiquetaElse + "_end");
                    cod3d.crearEtiqueta(etiqueta + "_end");
                    RESULT = blq2;
                :}

              | /* epsilon */
                {:
                    String etiqueta = etiquetaIfPendiente;
                    cod3d.crearEtiqueta(etiqueta + "_end");
                    RESULT = crearExpr("epsilon", "epsilon");
                :}
              ;

abrir_scope_while ::=
    {:
        tabla.crearNuevoScope(nuevoScope("dowhile"));
    :}
;

do_inicio ::= DO SEPARADOR abrir_scope_while
              {:
                  String doTemp = cod3d.nuevoDo();
                  String etiqueta = obtenerNombreFuncion(tabla.getCurrentScope()) + "_" + doTemp;
                  cod3d.crearEtiqueta(etiqueta);
                  RESULT = etiqueta;
              :}
            ;   

condicion_do ::= condicion:c
                {: RESULT = c; :}
                | error
                {: RESULT = crearExpr("error", "error"); :};

bloque_do_while ::= do_inicio:eti
                    INICIO_BLOQUE sentencias_break:s FINAL_BLOQUE
                    WHILE SEPARADOR INICIO_PAREN
                    {:
                        String etiqueta = eti.toString();
                        cod3d.crearEtiqueta(etiqueta + "_while");
                    :}
                    condicion_do:c
                    FINAL_PAREN FIN_EXPR
                    {:
                        String etiqueta = eti.toString();
                        String tipoCondicion = getTipoExpr(c.toString());
                        String valorCondicion = getValorExpr(c.toString());
                        if (!tipoCondicion.equals("error")) {
                            cod3d.genIf(valorCondicion, etiqueta);
                        }
                        cod3d.crearEtiqueta(etiqueta + "_end");
                        tabla.salirDelScope();
                        RESULT = crearExpr("return", "false");
                    :}
                  ;

abrir_scope_switch ::=
    {:
        tabla.crearNuevoScope(nuevoScope("switch"));
        casosActuales.clear();
        tipoSwitchActual = null;
        int numSwitch = cod3d.nuevoSwitch();
        etiquetaSwitchActual = obtenerNombreFuncion(tabla.getCurrentScope()) + "_switch_" + numSwitch;
        banderaSwitchActual = "fsw" + numSwitch;
        cod3d.reiniciarCases();
        cod3d.crearEtiqueta(etiquetaSwitchActual);
        cod3d.crearCodigo(banderaSwitchActual + " = 1");
    :}
;

bloque_switch ::= SWITCH SEPARADOR abrir_scope_switch
                  INICIO_PAREN expresion_aritmetica:e FINAL_PAREN
                  {:
                      tipoSwitchActual = getTipoExpr(e.toString());
                      String tipoE = getTipoExpr(e.toString());

                      if (!tipoE.equals("int") && !tipoE.equals("char") && !tipoE.equals("error")) {
                          manejadorErrores.agregarErrorSemantico(
                              "La expresión en un switch debe ser int o char, pero se encontró " + tipoE,
                              eleft + 1,
                              eright + 1
                          );
                      }
                      String valorE = getValorExpr(e.toString());
                      valorSwitchActual = cod3d.genTemporal(valorE);
                  :}
                  bloque_casos:b
                  {:
                      cod3d.crearEtiqueta(etiquetaSwitchActual + "_end");
                      tabla.salirDelScope();
                      tipoSwitchActual = null;
                      etiquetaSwitchActual = "";
                      valorSwitchActual = "";
                      banderaSwitchActual = "";
                      RESULT = crearExpr("return", "false");
                  :}

                | SWITCH SEPARADOR abrir_scope_switch
                  INICIO_PAREN error FINAL_PAREN
                  bloque_casos
                  {:
                      cod3d.crearEtiqueta(etiquetaSwitchActual + "_end");
                      tabla.salirDelScope();
                      tipoSwitchActual = null;
                      etiquetaSwitchActual = "";
                      valorSwitchActual = "";
                      banderaSwitchActual = "";
                      RESULT = crearExpr("return", "false");
                  :}
                ;

bloque_casos ::= INICIO_BLOQUE lista_casos:l FINAL_BLOQUE
                 {: RESULT = l; :}
               | INICIO_BLOQUE lista_casos:l default_case FINAL_BLOQUE
                 {: RESULT = l; :}
               ;

lista_casos ::= caso:c lista_casos:l
                {:
                    RESULT = c;
                :}
              | caso:c
                {:
                    RESULT = c;
                :}
              ;

sentencias_break ::= lista_sentencias:l break_nt:b
                     {: RESULT = l; :}
                   | break_nt:b
                     {: RESULT = b; :}
                   | lista_sentencias:l
                     {: RESULT = l; :}
                   ;

case_inicio ::= CASE SEPARADOR literal:l DOS_PUNTOS
                {:
                    String tipo = getTipoExpr(l.toString());
                    String valor = getValorExpr(l.toString());

                    if (!tipo.equals("int") && !tipo.equals("char") && !tipo.equals("error")) {
                        manejadorErrores.agregarErrorSemantico(
                            "El literal en un caso de switch debe ser int o char, pero se encontró " + tipo,
                            lleft + 1,
                            lright + 1
                        );
                    }
                    if (tipoSwitchActual != null &&
                        !tipoSwitchActual.equals("error") && !tipo.equals("error") && !tipo.equals(tipoSwitchActual)) {
                        manejadorErrores.agregarErrorSemantico(
                            "El tipo del case '" + valor + "' (" + tipo +
                            ") no es compatible con la expresión del switch (" + tipoSwitchActual + ")",
                            lleft + 1,
                            lright + 1
                        );
                    }
                    if (casosActuales.contains(valor)) {
                        manejadorErrores.agregarErrorSemantico(
                            "Valor de case '" + valor + "' ya ha sido declarado en este switch",
                            lleft + 1,
                            lright + 1
                        );
                    } else {
                        casosActuales.add(valor);
                    }
                    String etiquetaCase = cod3d.nuevoCase(etiquetaSwitchActual);
                    cod3d.crearEtiqueta(etiquetaCase);
                    String tBandera = cod3d.genTemporal(banderaSwitchActual);
                    String tCero1 = cod3d.genTemporal("0");
                    String tBanderaEsCero = cod3d.genOperacion(tBandera, "==", tCero1);
                    cod3d.genIf(tBanderaEsCero, etiquetaCase + "_bloque");
                    String tLiteral = cod3d.genTemporal(valor);
                    String tComparacion = cod3d.genOperacion(valorSwitchActual, "==", tLiteral);
                    cod3d.genIf(tComparacion, etiquetaCase + "_bloque");
                    cod3d.genGoto(etiquetaCase + "_end");
                    cod3d.crearEtiqueta(etiquetaCase + "_bloque");
                    String tCero2 = cod3d.genTemporal("0");
                    cod3d.genAsignacion(banderaSwitchActual, tCero2);
                    RESULT = crearExpr(etiquetaCase, tipo);
                :}
              ;

caso ::= case_inicio:c sentencias_break
         {:
             String etiquetaCase = getValorExpr(c.toString());
             cod3d.crearEtiqueta(etiquetaCase + "_end");
             RESULT = c;
         :}
       | case_inicio:c
         {:
             String etiquetaCase = getValorExpr(c.toString());
             cod3d.crearEtiqueta(etiquetaCase + "_end");
             RESULT = c;
         :}
       | CASE error DOS_PUNTOS lista_sentencias
         {:
             RESULT = crearExpr("case", "error");
         :}
       ;

default_inicio ::= DEFAULT SEPARADOR DOS_PUNTOS
                   {:
                       cod3d.crearEtiqueta(etiquetaSwitchActual + "_default");
                       RESULT = crearExpr(etiquetaSwitchActual + "_default", "default");
                   :}
                 ;

default_case ::= default_inicio sentencias_break
                 {: RESULT = crearExpr("default", "default"); :}

               | default_inicio
                 {: RESULT = crearExpr("default", "default"); :}

               | DEFAULT error lista_sentencias
                 {: RESULT = crearExpr("default", "error"); :}
               ;

break_nt ::= BREAK FIN_EXPR
             {:
                 cod3d.genGoto(etiquetaSwitchActual + "_end");
                 RESULT = crearExpr("break", "false");
             :}
           ;

return_nt ::= RETURN SEPARADOR expresion:e
            {:
                String scopeActual = tabla.getCurrentScope();

                if (scopeActual.contains("main")) {
                    manejadorErrores.agregarErrorSemantico(
                        "La función main no puede tener return",
                        eleft + 1,
                        eright + 1
                    );
                } else {
                    String tipoReturn = getTipoExpr(e.toString());

                    if (tipoFuncionActual != null && !tipoReturn.equals("error") && !tipoFuncionActual.equals(tipoReturn)) {
                        manejadorErrores.agregarErrorSemantico(
                            "La función debe retornar " + tipoFuncionActual +
                            " pero se encontró " + tipoReturn,
                            eleft + 1,
                            eright + 1
                        );
                    }
                    if (!tipoReturn.equals("error")) {
                            String valorReturn = getValorExpr(e.toString());
                            String tempReturn = cod3d.genTemporal(valorReturn);
                            cod3d.genReturn(tempReturn);
                    }
                }
                RESULT = crearExpr("return", "true");
            :}
        ;

cin_nt ::= CIN INICIO_PAREN ID:i FINAL_PAREN
           {:
                TablaSimbolos.NodoToken nodo = tabla.buscarSimboloEnScopeAccesible(i.toString());

                if (nodo == null) {
                    manejadorErrores.agregarErrorSemantico(
                        "La variable '" + i + "' no ha sido declarada",
                        ileft + 1,
                        iright + 1
                    );
                } else {
                    String tipo = nodo.getTipo();
                    if (!tipo.equals("int") && !tipo.equals("float")) {
                        manejadorErrores.agregarErrorSemantico(
                            "cin solo puede leer variables int o float, pero '" +
                            i + "' es de tipo " + tipo,
                            ileft + 1,
                            iright + 1
                        );
                    }
                    // Marcar intento de asignación cuando se usa cin
                    nodo.setIntentoAsignacion(true);
                    String temp = cod3d.genTemporal(i.toString());
                    cod3d.genRead(tipo, temp);
                    RESULT = crearExpr("cin", tipo);
                } 
           :};

cout_nt ::= COUT INICIO_PAREN expresion:e FINAL_PAREN
            {:
                String tipo = getTipoExpr(e.toString());

                if (tipo.equals("error")) {
                    // Si la expresión tiene error, no generar código para cout
                    RESULT = crearExpr("cout", "error");
                } else {
                    String valor = getValorExpr(e.toString());
                    String temp = cod3d.genTemporal(valor);
                    cod3d.genPrint(tipo, temp);
                    RESULT = crearExpr("cout", tipo);
                }
            :};

literal ::= numero:n
            {: RESULT = n; :}
          | bool_lit:b
            {: RESULT = b; :}
          | CHAR_LIT:c
            {: RESULT = crearExpr(c.toString(), "char"); :}
          | STRING_LITERAL:s
            {: RESULT = crearExpr(s.toString(), "string"); :}
            ;

numero ::= ENTERO:e
            {: RESULT = crearExpr(e.toString(), "int"); :}
         | FLOTANTE:f
            {: RESULT = crearExpr(f.toString(), "float"); :}
         | EXPONENCIAL:exp
            {: RESULT = crearExpr(exp.toString(), "float"); :}
         | FRACCION:fr
            {: RESULT = crearExpr(fr.toString(), "float"); :}
         ;

bool_lit ::= TRUE
            {: RESULT = crearExpr("true", "bool"); :}
           | FALSE
            {: RESULT = crearExpr("false", "bool"); :}
           ;

tipo ::= STRING {: RESULT = "string"; :}
       | CHAR   {: RESULT = "char"; :}
       | FLOAT  {: RESULT = "float"; :}
       | BOOL   {: RESULT = "bool"; :}
       | INT    {: RESULT = "int"; :};

